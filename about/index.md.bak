所有数据取白天数据。

体重和体脂率应当持续走低（下面的数据均是 7 天移动平均数据）。

<div style="display: flex; height: 400px; margin-bottom: 1em">
    <div id="体重变化" style="flex-basis: 0;flex-grow:1"></div>
    <div id="体脂率变化" style="flex-basis: 0;flex-grow:1"></div>
</div>

**体重应当越来越接近去脂体重**，但这张图做了调整，使得它们之间距离越远表示越接近。**去脂体重应当升高或维持不变**。

<div id="体重-去脂体重变化" style="width: 100%; height: 400px; margin-bottom: 1em"></div>

每周减重应当在 0.5 - 1 kg 范围内，这里记的是每天的近七天的平均减重。

<div id="每周减重" style="width: 100%; height: 400px; margin-bottom: 1em"></div>

下面的则是原始体重，使用了线性插值补全缺失数据。

<div id="原始体重" style="width: 100%; height: 400px; margin-bottom: 1em"></div>


<script>
// 计算去脂体重
for (data of DATAS) {
    data.push(data[1] * (1 - 0.01*data[2]))
}

// 体重
const bms = calculateRollingAverage(DATAS.map(x => [x[0], x[1]]))

// 体脂率
const tzls = calculateRollingAverage(DATAS.map(x => [x[0], x[2]]))

// 去脂体重
const lbms = calculateRollingAverage(DATAS.map(x => [x[0], x[3]]))
// 脂肪重量
const fatms = []
for(let i = 0; i < bms.length; i++) {
    fatms.push([bms[i][0], bms[i][1] - lbms[i][1]])
}

// 所有日期
const dates = bms.map(x => x[0])

const [minBM, maxBM] = [Math.min(...bms.map(x => x[1])), Math.max(...bms.map(x => x[1]))]
const [minLBM, maxLBM] = [Math.min(...lbms.map(x => x[1])), Math.max(...lbms.map(x => x[1]))]

// 体重变化趋势
{
    var chart = echarts.init(document.getElementById('体重变化'), 'dark');
    var option = {
        title: { text: '体重变化趋势' },
        tooltip: { trigger: 'axis' },
        xAxis: { type: 'category', data: dates }, 
        yAxis: [
            {
                type: 'value',
                name: '体重 (kg)',
                position: 'left',
                scale: true,
                axisLabel: {
                    formatter: function (value) {
                        return value.toFixed(2);  // 设置小数点后 2 位
                    }
                },
            },
        ],
        series: [
            {
                name: '体重',
                type: 'line',
                yAxisIndex: 0,  // 绑定到左 Y 轴
                data: bms.map(x => x[1]),
                smooth: true
            }
        ]
    };
    chart.setOption(option);
}
// 体脂率变化趋势
{
    var chart = echarts.init(document.getElementById('体脂率变化'), 'dark');
    var option = {
        title: { text: '体脂率变化趋势' },
        tooltip: { trigger: 'axis' },
        xAxis: { type: 'category', data: dates }, 
        yAxis: [
            {
                type: 'value',
                name: '体脂率（%）',
                position: 'left',
                scale: true,
                axisLabel: {
                    formatter: function (value) {
                        return value.toFixed(2);  // 设置小数点后 2 位
                    }
                },
            },
        ],
        series: [
            {
                name: '体脂率',
                type: 'line',
                data: tzls.map(x => x[1]),
                smooth: true
            }
        ]
    };
    chart.setOption(option);
}
// 体重 & 去脂体重趋势
{
    var chart = echarts.init(document.getElementById('体重-去脂体重变化'), 'dark');
    var option = {
        title: { text: '体重 & 去脂体重趋势' },
        tooltip: { trigger: 'axis' },
        legend: { data: ['体重', '去脂体重'] },
        xAxis: { type: 'category', data: dates }, 
        yAxis: [
            {
                type: 'value',
                name: '体重 (kg)',
                position: 'left',
                // alignTicks: true,  // 让两侧 Y 轴刻度对齐
                min: minBM - 0.5, max: maxBM + 0.5,
                scale: true,
                axisLabel: {
                    formatter: function (value) {
                        return value.toFixed(2);  // 设置小数点后 2 位
                    }
                },
                axisLine: { show: true, lineStyle: { color: '#5470C6' } } // 蓝色
            },
            {
                type: 'value',
                name: '去脂体重 (kg)',
                position: 'right',
                // alignTicks: true,
                min: maxLBM + 0.5 - (maxBM + 0.5 - minBM + 0.5), max: maxLBM + 0.5,
                scale: true,
                axisLabel: {
                    formatter: function (value) {
                        return value.toFixed(2);  // 设置小数点后 2 位
                    }
                },
                axisLine: { show: true, lineStyle: { color: '#91CC75' } } // 绿色
            }
        ],
        series: [
            {
                name: '体重',
                type: 'line',
                yAxisIndex: 0,  // 绑定到左 Y 轴
                data: bms.map(x => x[1]),
                smooth: true
            },
            {
                name: '去脂体重',
                type: 'line',
                yAxisIndex: 1,  // 绑定到右 Y 轴
                data: lbms.map(x => x[1]), 
                smooth: true
            }
        ]
    };
    chart.setOption(option);
}

{
    // 每周减重
    var chart = echarts.init(document.getElementById('每周减重'), 'dark');
    const averageWeekLose = bms.map(([date, value], i) => {
        const lastWeekValue = bms[Math.max(0, i - 7)][1]
        return [date, lastWeekValue - value]
    })
    const option = {
        title: { text: '周平均减重（kg），正数为减重' },
        tooltip: { trigger: 'axis' },
        legend: { data: ['周平均减重'] },
        xAxis: {
            type: 'category',
            data: averageWeekLose.map(x=>x[0]) // 你的日期数据
        },
        yAxis: {
            type: 'value',
            min: -1,  // 设置 y 轴最小值为 -1kg（可以根据需求调整）
            max: 1.5,   // 设置 y 轴最大值为 1kg
        },
        series: [
            {
            name: 'Weight Change (7 days)',
            type: 'line',
            data: averageWeekLose.map(x=>x[1].toFixed(2)),
            markArea: {
                    // silent: true,  // 设置为静默模式，使其不影响交互
                    itemStyle: {
                    color: 'rgba(0, 128, 0, 0.1)'  // 设置底色为淡绿色，可以根据需要调整
                    },
                    data: [
                    [
                        {
                        name: '减重 0.5 - 1kg（正常范围）',
                        yAxis: 0.5  // 区域下边界
                        },
                        {
                        yAxis: 1  // 区域上边界
                        }
                    ]]
                }
            }
        ],
    }
    chart.setOption(option);
}
{
    var chart = echarts.init(document.getElementById('原始体重'), 'dark');
    var option = {
        title: { text: '原始体重变化趋势' },
        tooltip: { trigger: 'axis' },
        xAxis: { type: 'category', data: dates }, 
        yAxis: [
            {
                type: 'value',
                name: '体重 (kg)',
                position: 'left',
                scale: true,
                axisLabel: {
                    formatter: function (value) {
                        return value.toFixed(2);  // 设置小数点后 2 位
                    }
                },
            },
        ],
        series: [
            {
                name: '体重',
                type: 'line',
                yAxisIndex: 0,  // 绑定到左 Y 轴
                data: interpolate(DATAS).map(x => x[1]),
                smooth: true
            }
        ]
    };
    chart.setOption(option);
}
